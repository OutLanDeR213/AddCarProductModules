<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Form view: add new fields -->
    <record id="fleet_vehicle_model_view_form_inherit" model="ir.ui.view">
        <field name="name">fleet.vehicle.model.form.inherit.add_car</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_model_view_form"/>
        <field name="arch" type="xml">

            <field name="category_id" position="after">
                <field name="model_type"/>
                <label string="Years" for="model_year_from"/>
                <div class="o_row">
                    <field name="model_year_from" nolabel="1"/>
                    <span class="mx-1">-</span>
                    <field name="model_year_to" nolabel="1"/>
                </div>
            </field>

            <field name="default_fuel_type" position="before">
                <field name="volume_id"/>
            </field>

            <field name="trailer_hook" position="after">
                <field name="ovoko_car_id"/>
            </field>

        </field>
    </record>

    <!-- List view: add new columns -->
    <record id="fleet_vehicle_model_view_tree_inherit" model="ir.ui.view">
        <field name="name">fleet.vehicle.model.list.inherit.add_car</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_model_view_tree"/>
        <field name="arch" type="xml">

            <field name="name" position="after">
                <field name="model_type"/>
                <field name="model_year_from" string="Year from"/>
                <field name="model_year_to" string="Year to"/>
                <field name="volume_id" string="Volume"/>
            </field>

            <field name="default_co2" position="replace">
                <field name="default_fuel_type" string="Fuel Type" optional="show"/>
                <field name="transmission" optional="show"/>
            </field>

        </field>
    </record>

</odoo>
