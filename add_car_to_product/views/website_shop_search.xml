<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="shop_vehicle_search" inherit_id="website_sale.products">
        <xpath expr="//div[@id='oe_structure_website_sale_products_1']" position="after">
            <div class="container-fluid py-3 bg-light border-bottom">
                <form method="get" action="/shop" class="d-flex gap-2 flex-wrap align-items-end">
                    <div>
                        <label class="form-label fw-bold mb-1">Manufacturer</label>
                        <select name="manufacturer_id" class="form-select" id="vehicle_manufacturer_select">
                            <option value="">All manufacturers</option>
                            <t t-foreach="vehicle_manufacturers" t-as="brand">
                                <option t-att-value="brand.id"
                                        t-att-selected="brand.id == selected_manufacturer_id">
                                    <t t-esc="brand.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <div>
                        <label class="form-label fw-bold mb-1">Model</label>
                        <select name="model_id" class="form-select" id="vehicle_model_select">
                            <option value="">All models</option>
                            <t t-foreach="vehicle_models" t-as="model">
                                <option t-att-value="model.id"
                                        t-att-selected="model.id == selected_model_id">
                                    <t t-esc="model.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <div>
                        <label class="form-label fw-bold mb-1">Year</label>
                        <input type="number" name="year" class="form-control"
                               placeholder="e.g. 2015" t-att-value="selected_year"
                               style="width: 110px;"/>
                    </div>
                    <div>
                        <label class="form-label fw-bold mb-1">Volume</label>
                        <select name="volume_id" class="form-select" id="vehicle_volume_select">
                            <option value="">All volumes</option>
                            <t t-foreach="vehicle_volumes" t-as="vol">
                                <option t-att-value="vol.id"
                                        t-att-selected="vol.id == selected_volume_id">
                                    <t t-esc="vol.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Search</button>
                        <a href="/shop" class="btn btn-outline-secondary">Clear</a>
                    </div>
                </form>
            </div>
        </xpath>
    </template>

</odoo>
